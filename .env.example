# MakeCrazyPenny — environment configuration
# Copy this file to `.env` and fill in the values you have. NEVER commit `.env`.
# Every key below is OPTIONAL: providers whose key is missing raise MissingApiKey
# at fetch time, and the registry falls through to the next provider in the chain.
#
# NOTE: No ANTHROPIC_API_KEY is needed for the decision system. The MCP server
# (makecrazypenny-mcp) runs the bull/bear/judge debate on your MCP HOST's model
# (your Claude subscription). The data-provider keys below are the only secrets,
# and even those are optional (yfinance needs none).

# --- API keys (free-tier acceptable) -----------------------------------------

# Alpha Vantage — ohlcv, quote, news_sentiment, fundamentals (free tier: 5 req/min, 500/day)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub — ohlcv, quote, news, sentiment, congress, insider, ratings, targets, upgrades (60 req/min)
# https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Financial Modeling Prep — congress trades, ratings, price targets, upgrades/downgrades, fundamentals
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Marketaux — company news (free tier)
# https://www.marketaux.com/account/dashboard
MARKETAUX_API_KEY=

# --- Crypto (CONTRACT.md §16) --------------------------------------------------
# All crypto data sources are KEYLESS: Binance + Bybit (perp klines, funding, open
# interest, long/short), CoinGecko (global market cap / BTC dominance), and
# Alternative.me (Fear & Greed). Nothing below is required.

# Optional CoinGecko demo key — lifts the public rate limit (sent as a header).
# https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Optional exchange REST base-URL overrides (for proxies / regional mirrors).
# Binance global (fapi.binance.com) is geo-blocked from US IPs; the registry falls
# through to Bybit automatically, so these are only needed for custom routing.
# MCP_BINANCE_BASE_URL=https://fapi.binance.com
# MCP_BYBIT_BASE_URL=https://api.bybit.com

# Crypto leverage-risk policy (informational sizing). Defaults shown ("aggressive").
# MCP_CRYPTO_MAX_LEVERAGE=20        # cap on suggested leverage
# MCP_CRYPTO_RISK_PER_TRADE=0.025   # equity fraction lost if the stop triggers
# MCP_CRYPTO_MAINT_MARGIN=0.005     # maintenance margin rate (liquidation estimate)
# MCP_CRYPTO_TARGET_VOL=0.80        # annualized vol target for the regime overlay
# MCP_CRYPTO_LIQ_BUFFER=0.5         # stop must sit >=1.5x its distance inside liquidation

# --- Cache ---------------------------------------------------------------------

# Directory for the on-disk L2 cache and persisted alert state.
# Defaults to a platform temp/`.mcpenny_cache` location if unset.
MCP_CACHE_DIR=
