# MakeCrazyPenny — environment configuration
# Copy this file to `.env` and fill in the values you have. NEVER commit `.env`.
# Every key below is OPTIONAL: providers whose key is missing raise MissingApiKey
# at fetch time, and the registry falls through to the next provider in the chain.

# --- API keys (free-tier acceptable) -----------------------------------------

# Alpha Vantage — ohlcv, quote, news_sentiment, fundamentals (free tier: 5 req/min, 500/day)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub — ohlcv, quote, news, sentiment, congress, insider, ratings, targets, upgrades (60 req/min)
# https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Financial Modeling Prep — congress trades, ratings, price targets, upgrades/downgrades, fundamentals
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Marketaux — company news (free tier)
# https://www.marketaux.com/account/dashboard
MARKETAUX_API_KEY=

# --- Cache ---------------------------------------------------------------------

# Directory for the on-disk L2 cache and persisted alert state.
# Defaults to a platform temp/`.mcpenny_cache` location if unset.
MCP_CACHE_DIR=
